  "keyFeatures": [
    "Full member lifecycle management with advanced filters and search",
    "New-member integration pipeline with mentor assignment and conversion flow",
    "Multi-congregation structure with individual management",
    "Groups and ministries management",
    "Church event calendar with participant tracking",
    "Analytics dashboard with demographic, structural, and temporal reports",
    "PDF export for members, lists, and dashboards",
    "Public self-registration and integration links (no login required)",
    "Multi-tenant data isolation per church",
    "Role-based access control (owner, admin, editor, reader)",
    "Stripe-powered subscription plans (Free/200/500/800 members)"
  ],
